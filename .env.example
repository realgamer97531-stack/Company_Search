# Database Configuration
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=root
DB_NAME=company_search
DB_PORT=3306

# Optional: use one connection URL instead of DB_HOST/DB_USER/DB_PASSWORD/DB_NAME
# DATABASE_URL=mysql://user:password@host:3306/company_search

# Enable if your hosted MySQL provider requires TLS/SSL
DB_SSL=false
DB_SSL_REJECT_UNAUTHORIZED=true

# Server Configuration
PORT=3000
ALLOWED_ORIGINS=https://company-search-beryl.vercel.app

# JWT Secret
JWT_SECRET=SUPER_SECRET_KEY
SUPER_SECRET_KEY=SUPER_SECRET_KEY

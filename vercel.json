{
  "version": 2,
  "rewrites": [
    {
      "source": "/",
      "destination": "/client/index.html"
    },
    {
      "source": "/login.html",
      "destination": "/client/login.html"
    },
    {
      "source": "/add-link.html",
      "destination": "/client/add-link.html"
    },
    {
      "source": "/edit-link.html",
      "destination": "/client/edit-link.html"
    },
    {
      "source": "/stats.html",
      "destination": "/client/stats.html"
    },
    {
      "source": "/users.html",
      "destination": "/client/users.html"
    },
    {
      "source": "/dashboard.html",
      "destination": "/client/dashboard.html"
    },
    {
      "source": "/uploads/:path*",
      "destination": "/client/uploads/:path*"
    },
    {
      "source": "/:file((?:[^/]+)\\.(?:js|css|png|jpg|jpeg|gif|svg|ico|webp))",
      "destination": "/client/:file"
    }
  ]
}
